--- !u!114 &1032106492
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1032106490}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d8ba876a9034460dbaef1834d4970947, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  CurrentLogLevel: 2
  m_statusReadOnly: 
  _toolName: ToDoListDisplayTool
  _toolPriority: 1000
  _descriptionForPrompt: "Use this tool when the user asks to see, show, or hide
    the full to-do list. This displays the task list in a large UI view instead of
    returning it in the assistant reply.\n\nWhen showing the list, return the tasks
    in the items array with a status and item text.\n\nAllowed status values:\n-
    in progress\n- pending\n- blocked\n- finished\n\nIf the user asks to show the
    to-do list for a specific time, convert that request to durationMinutes as a
    float in minutes.\n\nExamples:\n- 20 minutes \u2192 20\n- 30 seconds \u2192 0.5\n-
    1 hour \u2192 60\n\nRules:\n- If the user says \"show the to-do list\", default
    to durationMinutes = 5.\n- If the user asks to keep the list visible indefinitely,
    omit durationMinutes.\n- If the user asks to hide or close the list, set option
    to \"hide\".\n- If the user asks to show it, set option to \"show\"."
  _jsonPayloadExampleForPrompt: "A valid example payload:\n{\n  \"option\": \"show\",\n 
    \"durationMinutes\": 5,\n  \"items\": [\n    {\n      \"status\": \"in progress\",\n     
    \"item\": \"Implement OpenClawTool\"\n    },\n    {\n      \"status\": \"in progress\",\n     
    \"item\": \"Tune proactive loop behavior\"\n    },\n    {\n      \"status\":
    \"pending\",\n      \"item\": \"Hook up Trello task sync\"\n    },\n    {\n     
    \"status\": \"pending\",\n      \"item\": \"Add Discord log export tool\"\n   
    },\n    {\n      \"status\": \"blocked\",\n      \"item\": \"Waiting for OpenClaw
    API key\"\n    },\n    {\n      \"status\": \"finished\",\n      \"item\": \"Implement
    SettingsTool\"\n    }\n  ]\n}\n\nanother valid example payload:\n{\n  \"option\":
    \"show\",\n  \"durationMinutes\": 0.5,\n  \"items\": [\n    {\n      \"status\":
    \"pending\",\n      \"item\": \"Check stream setup\"\n    }\n  ]\n}\n\nanother
    valid example payload:\n{\n  \"option\": \"hide\",\n  \"items\": []\n}"
  _toDoListDisplayPrefab: {fileID: 2003458453}
  _toDoListText: {fileID: 954012135}
