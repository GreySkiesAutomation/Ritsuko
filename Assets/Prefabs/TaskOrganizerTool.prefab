  CurrentLogLevel: 3
  m_statusReadOnly: 
  _toolName: TaskOrganizer
  _toolPriority: 0
  _descriptionForPrompt: "Manage the assistant's internal to-do list.\n\nUse when
    the user requests task changes:\ncreateTask | deleteTask | rename | setCategory
    | setPriority | setUrgency | setStatus | setNotes\n\nRules:\n- Never invent tasks.\n-
    createTask auto-assigns taskId.\n- Other actions require taskId.\n- Payload =
    one action object or an array of actions.\n- Prefer batching multiple actions.\n-
    name max 128 chars; notes max 256 chars.\n- Missing createTask fields default
    to:\n  category=UNDEFINED\n  priority=UNDEFINED\n  urgency=UNDEFINED\n  status=PENDING\n\nEnums:\ncategory:
    UNDEFINED|WORK|PERSONAL|HOBBY|DOMESTIC|RITSUKO\npriority: UNDEFINED|LOW|MEDIUM|HIGH\nurgency:
    UNDEFINED|LOW|MEDIUM|HIGH\nstatus: PENDING|INPROGRESS|BLOCKED|DONE|CANCELLED\n\nAfter
    any modification:\nCall ToDoListDisplayTool with default duration 5 minutes."
  _jsonPayloadExampleForPrompt: "Create\n{\n  \"action\":\"createTask\",\n  \"name\":\"Investigate
    webcam timeout\"\n}\n\nStatus\n{\n  \"action\":\"setStatus\",\n  \"taskId\":12,\n 
    \"status\":\"INPROGRESS\"\n}\n\nBatch\n[\n  {\n    \"action\":\"createTask\",\n   
    \"name\":\"Fix prompt formatting\",\n    \"category\":\"RITSUKO\"\n  },\n  {\n   
    \"action\":\"setStatus\",\n    \"taskId\":7,\n    \"status\":\"DONE\"\n  }\n]"
