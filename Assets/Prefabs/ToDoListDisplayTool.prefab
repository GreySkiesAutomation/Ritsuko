  _toolName: ToDoListDisplayTool
  _toolPriority: 1000
  _descriptionForPrompt: 'Control full to-do list UI visibility.


    Use when the
    user asks to show/open/display or hide/close the to-do list.


    Text source
    rule:

    If the request comes from text, ignore unless the user explicitly
    asks to show it on your screen.


    Rules:

    - Payload is visibility only.

    -
    Never include task items.

    - The tool reads current internal task state.

    -
    option: show|hide

    - If durationMinutes is provided, it must be >0.

    -
    show + no durationMinutes = show indefinitely.

    - show + no user-specified
    duration = durationMinutes 5.

    - hide does not need durationMinutes.'
  _jsonPayloadExampleForPrompt: 'Show default

    {"option":"show","durationMinutes":5}


    Show
    timed

    {"option":"show","durationMinutes":0.5}


    Show indefinite

    {"option":"show"}


    Hide

    {"option":"hide"}'
  _toDoListDisplayPrefab: {fileID: 0}
  _toDoListText: {fileID: 0}
  _importantTextColor: {r: 0.6431373, g: 0, b: 0.07445346, a: 1}
  _normalTextColor: {r: 0.02761037, g: 0, b: 0.21698111, a: 1}
  _urgentPrefix: '[URGENT] '
  _highPriorityPrefix: '[IMPORTANT] '
