  _toolName: ToDoListDisplayTool
  _toolPriority: 1000
  _descriptionForPrompt: "Control visibility of the full to-do list UI.\n\nUse when
    the user asks to show/open/display or hide/close the to-do list.\n\nText vs speech:\nIf
    the request comes from text (e.g. Discord), ignore unless the user explicitly
    asks to show it on your screen.\n\nRules:\n- Payload controls visibility only.\n-
    Never include or reconstruct task items.\n- The UI reads the current internal
    task state.\n\nOptions:\nshow | hide\n\nDuration:\n- If user specifies time \u2192
    convert to durationMinutes (float minutes).\n- If unspecified \u2192 default
    durationMinutes = 5.\n- If user wants it indefinitely \u2192 omit durationMinutes."
  _jsonPayloadExampleForPrompt: '{ "option":"show","durationMinutes":5 }


    {
    "option":"show","durationMinutes":0.5 }


    { "option":"show" }


    { "option":"hide"
    }'
